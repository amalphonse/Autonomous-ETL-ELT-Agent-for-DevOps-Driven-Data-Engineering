# Autonomous ETL/ELT Agent Environment Configuration
# 
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control (use .env.example for documentation)

# ============================================================================
# Environment Configuration
# ============================================================================
# Environment: development, staging, production
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# OpenAI Configuration
# ============================================================================
# Your OpenAI API key for GPT-4o access
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# The LLM model to use (recommended: gpt-4o)
OPENAI_MODEL=gpt-4o

# ============================================================================
# GitHub Configuration
# ============================================================================
# Your GitHub personal access token
# Create at: https://github.com/settings/tokens
# Required scopes: 'repo' (for PR creation) and 'workflow' (for CI/CD)
GITHUB_TOKEN=ghp_your-github-token-here

# Repository owner (your GitHub username)
GITHUB_REPO_OWNER=amalphonse

# Repository name
GITHUB_REPO_NAME=Autonomous-ETL-ELT-Agent-for-DevOps-Driven-Data-Engineering

# ============================================================================
# Google Cloud Platform Configuration
# ============================================================================
# Your GCP project ID for BigQuery and Data Warehouse operations
# Find it in: https://console.cloud.google.com/home/dashboard
GCP_PROJECT_ID=your-gcp-project-id-here

# ============================================================================
# Database Configuration
# ============================================================================
# Database driver: sqlite or postgresql
# Development default: sqlite
# Production recommended: postgresql
DB_DRIVER=sqlite

# For PostgreSQL only:
DB_HOST=localhost
DB_PORT=5432
DB_USER=etl_user
DB_PASSWORD=etl_password
DB_NAME=etl_agent_db

# Or provide complete DATABASE_URL override (optional):
# DATABASE_URL=postgresql://etl_user:etl_password@localhost:5432/etl_agent_db

# Enable SQL query logging (development: true, production: false)
DB_ECHO=false

# ============================================================================
# API Configuration (Optional)
# ============================================================================
# FastAPI server host (default: 0.0.0.0)
# API_HOST=0.0.0.0

# FastAPI server port (default: 8000)
# API_PORT=8000

# ============================================================================
# Setup Instructions
# ============================================================================
# 
# 1. Rename this file:
#    mv .env.example .env
#
# 2. Fill in your API keys and credentials
#
# 3. Keep .env secure:
#    - Never commit to version control
#    - Add to .gitignore (already included)
#    - Restrict file permissions: chmod 600 .env
#
# 4. For Local Development (SQLite):
#    python3.12 -m uvicorn src.api:app --reload
#
# 5. For Docker Development (PostgreSQL):
#    docker-compose up --build
#
# 6. Test with sample request:
#    curl -X POST http://localhost:8000/pipelines/create \
#      -H "Content-Type: application/json" \
#      -d '{
#        "title": "Test ETL Pipeline",
#        "description": "Load sample data"
#      }'
#
# ============================================================================
# Production Deployment Notes
# ============================================================================
# - Set ENVIRONMENT=production
# - Use PostgreSQL database (DB_DRIVER=postgresql)
# - Ensure OPENAI_API_KEY and GITHUB_TOKEN are secure (use AWS Secrets Manager, etc.)
# - Enable HTTPS/TLS in production
# - Use gunicorn or similar for production ASGI server
# - Set up monitoring and logging aggregation
# - Use health checks at /health endpoint
#
# ============================================================================
