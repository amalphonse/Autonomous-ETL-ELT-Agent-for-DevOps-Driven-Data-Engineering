# ⚠️  IMPORTANT SECURITY WARNING
# =============================
# This is an EXAMPLE file - NEVER commit real credentials to .env!
# For production, use GCP Secret Manager, GitHub Secrets, or your CI/CD tool's secret management.
# 
# Local Development:
#   1. Copy to .env: cp .env.example .env
#   2. Fill in local credentials
#   3. Run locally: python -m uvicorn src.api:app --reload
#   4. Ensure .env is in .gitignore (already configured)
#
# Cloud Run Production:
#   1. Use environment variables from GCP Cloud Run settings
#   2. Use GCP Secret Manager for sensitive values
#   3. Never expose credentials in container images
#   4. Use Workload Identity for GCP service access
#
# =============================

# ENVIRONMENT CONFIGURATION
# =============================
# Environment: development, staging, production
# WARNING: Set to "production" only when deploying to Cloud Run!
ENVIRONMENT=development
LOG_LEVEL=INFO

# API SECURITY (CRITICAL FOR PRODUCTION)
# =============================
# API Key for Bearer token authentication
# ⚠️  REQUIRED in production
# Generate with: openssl rand -base64 32
# Leave empty for local development
API_KEY=

# OPENAI CONFIGURATION (REQUIRED)
# =============================
# Your OpenAI API key
# Get from: https://platform.openai.com/api-keys
# Format: sk-proj-...
# ⚠️  NEVER commit this to git!
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY

# OpenAI model and settings
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.3

# GITHUB CONFIGURATION (REQUIRED)
# =============================
# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Required scopes: repo (full control of private repositories)
# Format: ghp_...
# ⚠️  NEVER commit this to git!
GITHUB_TOKEN=ghp_YOUR_GITHUB_TOKEN

# GitHub repository configuration
GITHUB_REPO_OWNER=your-username
GITHUB_REPO_NAME=your-repo-name

# GOOGLE CLOUD CONFIGURATION (REQUIRED)
# =============================
# Your GCP Project ID
# Find at: https://console.cloud.google.com/home/dashboard
# Example: my-project-123456
GCP_PROJECT_ID=your-gcp-project-id

# GCP service account credentials (optional, use Workload Identity in GKE/Cloud Run)
GCP_CREDENTIALS_PATH=

# BigQuery configuration
BQ_DATASET=etl_automation
BQ_TABLE_PREFIX=pipeline_

# DATABASE CONFIGURATION
# =============================
# Database driver
# Development: sqlite (file-based, convenient)
# Production: postgresql (requires Cloud SQL)
DB_DRIVER=sqlite

# SQLite configuration (ignored if using PostgreSQL)
# Database file path
# DATABASE_URL=sqlite:///./etl_agent.db

# PostgreSQL configuration (for production)
DB_HOST=localhost
DB_PORT=5432
DB_USER=etl_user
DB_PASSWORD=CHANGE_THIS_PASSWORD_IN_PRODUCTION
DB_NAME=etl_agent_db

# Optional: Full database URL (overrides individual parameters)
# For Cloud SQL with Cloud SQL Proxy: postgresql://user:pass@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE
# For Cloud SQL in GKE: postgresql://user:pass@cloud-sql-proxy:5432/dbname
# DATABASE_URL=

# Enable SQL query logging (DEVELOPMENT ONLY)
DB_ECHO=false

# API CONFIGURATION
# =============================
# Server host binding
APP_HOST=0.0.0.0

# Server port
APP_PORT=8000

# CORS CONFIGURATION (for Cloud Run)
# =============================
# Comma-separated list of allowed origins
# Development: * (allow all)
# Production: specific domains only
ALLOWED_ORIGINS=*

# Trusted hosts for security
TRUSTED_HOSTS=localhost,127.0.0.1

# SPARK CONFIGURATION
# =============================
SPARK_MASTER=local[*]

# Delta Lake path (optional)
DELTA_LAKE_PATH=/tmp/delta-tables

# =============================
# DEPLOYMENT TEMPLATES
# =============================

# LOCAL DEVELOPMENT EXAMPLE:
# ENVIRONMENT=development
# OPENAI_API_KEY=sk-proj-...
# GITHUB_TOKEN=ghp_...
# GCP_PROJECT_ID=...
# DB_DRIVER=sqlite
# API_KEY= (empty - auth disabled)
# ALLOWED_ORIGINS=*

# CLOUD RUN PRODUCTION EXAMPLE:
# ENVIRONMENT=production
# DB_DRIVER=postgresql
# DATABASE_URL=postgresql://user:pass@cloudsql-proxy:5432/dbname
# OPENAI_API_KEY=<from Secret Manager>
# GITHUB_TOKEN=<from Secret Manager>
# API_KEY=<from Secret Manager>
# ALLOWED_ORIGINS=https://your-domain.com
# TRUSTED_HOSTS=your-api-domain.run.app

# =============================
# SECURITY CHECKLIST  
# =============================
# Before production deployment:
# ☐ All required environment variables are set
# ☐ API_KEY is a strong random value (generated with openssl)
# ☐ Database is PostgreSQL (not SQLite) in production
# ☐ Secrets are stored in GCP Secret Manager
# ☐ ENVIRONMENT is set to "production"
# ☐ This .env file is NOT committed to git
# ☐ .env is in .gitignore
# ☐ File permissions are restricted (chmod 600 .env)
# ☐ No credentials appear in container images or git history
#    docker-compose up --build
#
# 6. Test with sample request:
#    curl -X POST http://localhost:8000/pipelines/create \
#      -H "Content-Type: application/json" \
#      -d '{
#        "title": "Test ETL Pipeline",
#        "description": "Load sample data"
#      }'
#
# ============================================================================
# Production Deployment Notes
# ============================================================================
# - Set ENVIRONMENT=production
# - Use PostgreSQL database (DB_DRIVER=postgresql)
# - Ensure OPENAI_API_KEY and GITHUB_TOKEN are secure (use AWS Secrets Manager, etc.)
# - Enable HTTPS/TLS in production
# - Use gunicorn or similar for production ASGI server
# - Set up monitoring and logging aggregation
# - Use health checks at /health endpoint
#
# ============================================================================
